# versions.env — single source of truth for pinned Docker image versions
#
# Sourced by the systemd service (aquarco-stack.service) in production mode.
# Referenced by all compose files (compose.yml, compose.prod.yml, compose.dev.yml,
# compose.monitoring.yml) via variable substitution with matching fallback defaults.
#
# Bump these versions explicitly per release — never use "latest".

AQUARCO_REGISTRY=aquarco

AQUARCO_POSTGRES_VERSION=16-alpine
AQUARCO_CADDY_VERSION=2-alpine
AQUARCO_PROMETHEUS_VERSION=v3.11.2
AQUARCO_GRAFANA_VERSION=13.0.1
AQUARCO_LOKI_VERSION=3.7.1
AQUARCO_ADMINER_VERSION=5
AQUARCO_API_VERSION=PLACEHOLDER_VERSION
AQUARCO_WEB_VERSION=PLACEHOLDER_VERSION
AQUARCO_MIGRATIONS_VERSION=PLACEHOLDER_VERSION

POSTGRES_USER=aquarco
POSTGRES_DB=aquarco
