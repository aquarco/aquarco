# versions.env — single source of truth for pinned Docker image versions
#
# Sourced by the systemd service (aquarco-stack.service) in production mode.
# Referenced by docker/compose.prod.yml via variable substitution.
#
# Bump these versions explicitly per release — never use "latest".

AQUARCO_REGISTRY=ghcr.io/borissuska/aquarco

AQUARCO_POSTGRES_VERSION=16-alpine
AQUARCO_CADDY_VERSION=2-alpine
AQUARCO_API_VERSION=0.1.0
AQUARCO_WEB_VERSION=0.1.0
AQUARCO_MIGRATIONS_VERSION=0.1.0
