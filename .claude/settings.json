{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/orchestrate-on-change.sh",
            "timeout": 15,
            "async": false
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(jq *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(date *)",
      "Bash(grep *)",
      "Read(**)",
      "Bash(docker compose ps)",
      "Bash(docker compose logs *)",
      "Bash(npm run *)",
      "Bash(npx *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(DROP TABLE*)"
    ]
  }
}
