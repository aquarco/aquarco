{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aquarco.agents/schemas/system-agent-v1.json",
  "title": "SystemAgentDefinition",
  "description": "Schema for Aquarco system agent definitions — agents that orchestrate pipeline execution",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "aquarco.agents/v1",
      "description": "API version — must be exactly aquarco.agents/v1"
    },
    "kind": {
      "type": "string",
      "const": "AgentDefinition",
      "description": "Resource kind — must be exactly AgentDefinition"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "version", "description"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Unique identifier in kebab-case"
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$",
          "description": "Semantic version (semver 2.0.0 compatible)"
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "description": "Human-readable description of the agent's purpose"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Arbitrary string labels for filtering and selection"
        }
      }
    },
    "spec": {
      "type": "object",
      "required": ["role", "promptFile"],
      "additionalProperties": false,
      "properties": {
        "role": {
          "type": "string",
          "enum": ["planner", "condition-evaluator", "repo-descriptor"],
          "description": "Functional role of the system agent. Must be one of the recognised values — extend this enum when adding new system agents."
        },
        "promptFile": {
          "type": "string",
          "minLength": 1,
          "description": "Filename of the system prompt markdown (relative to agents/prompts/)"
        },
        "tools": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allowed": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true,
              "description": "Whitelist of allowed tool names — if omitted, all tools are allowed"
            },
            "denied": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true,
              "description": "Blacklist of denied tool names — takes precedence over allowed"
            }
          }
        },
        "resources": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxTokens": {
              "type": "integer",
              "minimum": 1000,
              "description": "Maximum tokens per agent invocation"
            },
            "timeoutMinutes": {
              "type": "integer",
              "minimum": 1,
              "maximum": 480,
              "description": "Execution timeout in minutes"
            },
            "maxConcurrent": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10,
              "description": "Maximum concurrent instances of this agent"
            },
            "memoryMB": {
              "type": "integer",
              "minimum": 128,
              "description": "Memory limit for the agent process in megabytes"
            },
            "maxTurns": {
              "type": "integer",
              "minimum": 1,
              "maximum": 20,
              "default": 5,
              "description": "Maximum conversation turns — system agents are kept low (max 20)"
            },
            "maxCost": {
              "type": "number",
              "minimum": 0.01,
              "default": 0.5,
              "description": "Maximum cumulative cost in USD per invocation"
            }
          }
        },
        "environment": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Environment variables passed to the agent process"
        },
        "healthCheck": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Whether the supervisor polls this agent's health"
            },
            "intervalSeconds": {
              "type": "integer",
              "minimum": 30,
              "default": 300,
              "description": "How often (seconds) to run the health check"
            }
          }
        }
      }
    }
  }
}
