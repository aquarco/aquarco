{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aquarco.agents/schemas/pipeline-definition-v1.json",
  "title": "PipelineDefinition",
  "description": "Schema for Aquarco pipeline definition YAML files (aquarco.agents/v1)",
  "type": "object",
  "required": ["apiVersion", "kind", "pipelines"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "aquarco.agents/v1",
      "description": "API version — must be exactly aquarco.agents/v1"
    },
    "kind": {
      "type": "string",
      "const": "PipelineDefinition",
      "description": "Resource kind — must be exactly PipelineDefinition"
    },
    "categories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Category"
      },
      "description": "Category definitions with output schemas"
    },
    "pipelines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Pipeline"
      },
      "description": "List of pipeline definitions"
    }
  },
  "$defs": {
    "Category": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Category name (e.g., analyze, design, implementation)"
        },
        "outputSchema": {
          "type": "object",
          "description": "JSON Schema defining the structured output for this category"
        }
      }
    },
    "Pipeline": {
      "type": "object",
      "required": ["name", "version", "trigger", "stages"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Unique pipeline identifier in kebab-case"
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$",
          "description": "Semantic version (semver 2.0.0 compatible)"
        },
        "trigger": {
          "$ref": "#/$defs/Trigger"
        },
        "stages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/Stage"
          },
          "description": "Ordered list of pipeline stages"
        }
      }
    },
    "Trigger": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "labels": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true,
          "description": "Issue/PR labels that activate this pipeline"
        },
        "events": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true,
          "description": "Event types that activate this pipeline"
        }
      }
    },
    "Stage": {
      "type": "object",
      "required": ["name", "category"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique stage name within the pipeline (used for condition jumps)"
        },
        "category": {
          "type": "string",
          "description": "Agent category for this stage"
        },
        "required": {
          "type": "boolean",
          "default": true,
          "description": "Whether this stage must succeed for the pipeline to continue"
        },
        "conditions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Condition"
          },
          "description": "Exit-gate conditions evaluated after stage completion"
        }
      }
    },
    "Condition": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        { "required": ["simple"] },
        { "required": ["ai"] }
      ],
      "properties": {
        "simple": {
          "type": ["string", "boolean"],
          "description": "Expression evaluated against stage outputs (supports ==, !=, >=, >, <=, <, &&, ||, parentheses). Boolean true means always-true."
        },
        "ai": {
          "type": "string",
          "description": "Natural-language condition evaluated by Claude CLI"
        },
        "yes": {
          "type": "string",
          "description": "Stage name to jump to when condition evaluates to true"
        },
        "no": {
          "type": "string",
          "description": "Stage name to jump to when condition evaluates to false"
        },
        "maxRepeats": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum number of times the target stage can be revisited via this condition"
        }
      }
    }
  }
}
