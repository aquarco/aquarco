# Template for target repository Docker Compose stack
# Copied to each repo's directory and customized by the supervisor via repo-manager.sh.
# Variables of the form ${VAR:-default} are resolved by Docker Compose at runtime from
# the .env file placed alongside this file.  __PLACEHOLDERS__ are substituted by sed
# inside repo-manager.sh before the file reaches Docker Compose.

name: aquarco-${REPO_NAME:-repo}

networks:
  default:
    name: aquarco-${REPO_NAME:-repo}

volumes:
  frontend_modules:
  api_modules:
  pgdata:

services:

  # ── Frontend (Next.js) ───────────────────────────────────────────────────────
  frontend:
    image: node:20-alpine
    restart: unless-stopped
    working_dir: /app
    command: >
      sh -c "
        if [ -f /app/package.json ]; then
          npm install && npm run dev
        else
          echo 'No package.json in /app — skipping frontend' && sleep infinity
        fi
      "
    ports:
      - "${FRONTEND_PORT:-3000}:3000"
    volumes:
      - ./frontend:/app:delegated
      - frontend_modules:/app/node_modules
    environment:
      NODE_ENV: development
      NEXT_PUBLIC_API_URL: http://localhost:${API_PORT:-4000}/graphql
    depends_on:
      api:
        condition: service_started

  # ── GraphQL API ───────────────────────────────────────────────────────────────
  api:
    image: node:20-alpine
    restart: unless-stopped
    working_dir: /app
    command: >
      sh -c "
        if [ -f /app/package.json ]; then
          npm install && npm run dev
        else
          echo 'No package.json in /app — skipping api' && sleep infinity
        fi
      "
    ports:
      - "${API_PORT:-4000}:4000"
    volumes:
      - ./api:/app:delegated
      - api_modules:/app/node_modules
    environment:
      NODE_ENV: development
      PORT: "4000"
      DATABASE_URL: >-
        postgresql://${POSTGRES_USER:-dev}:${POSTGRES_PASSWORD:-dev}@postgres:5432/${POSTGRES_DB:-dev}
    depends_on:
      migrations:
        condition: service_completed_successfully

  # ── Database Migrations (yoyo) ────────────────────────────────────────────────
  migrations:
    build:
      context: ./db
    restart: "no"
    volumes:
      - ./db/migrations:/db/migrations:ro
      - ./db/yoyo.ini:/db/yoyo.ini:ro
    environment:
      DATABASE_URL: >-
        postgresql://${POSTGRES_USER:-dev}:${POSTGRES_PASSWORD:-dev}@postgres:5432/${POSTGRES_DB:-dev}
    depends_on:
      postgres:
        condition: service_healthy

  # ── PostgreSQL ────────────────────────────────────────────────────────────────
  # NOTE: Per-repo sandboxes intentionally stay on postgres:16-alpine, which
  # uses the legacy PGDATA layout at /var/lib/postgresql/data. This is NOT a
  # mistake or drift from docker/compose.yml and docker/compose.prod.yml —
  # those files moved to postgres:18-alpine + `pgdata:/var/lib/postgresql`
  # because pg18 stores PGDATA in a versioned subdirectory
  # (/var/lib/postgresql/<MAJOR>/docker). Per-repo stacks are ephemeral
  # developer sandboxes with no persistence contract, so they do not need to
  # track the main-stack upgrade. If this template is ever bumped to pg18+,
  # the mount MUST change to `pgdata:/var/lib/postgresql` to match.
  postgres:
    image: postgres:16-alpine
    restart: unless-stopped
    ports:
      - "${POSTGRES_PORT:-5432}:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    environment:
      POSTGRES_USER: ${POSTGRES_USER:-dev}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-dev}
      POSTGRES_DB: ${POSTGRES_DB:-dev}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-dev}"]
      interval: 5s
      timeout: 5s
      retries: 5
