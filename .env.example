# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=aifishtank
POSTGRES_PASSWORD=aifishtank
POSTGRES_DB=aifishtank

# ── API ───────────────────────────────────────────────────────────────────────
# postgres service is reachable by service name inside Docker network
DATABASE_URL=postgresql://aifishtank:aifishtank@postgres:5432/aifishtank
PORT=4000
NODE_ENV=development

# ── Web UI ────────────────────────────────────────────────────────────────────
# URL used by the browser (not the Docker network) to reach the API
NEXT_PUBLIC_API_URL=http://localhost:4000/graphql
