# Vagrantfile — Aquarco VM
# Ubuntu 24.04 LTS with VirtualBox NAT networking and port forwarding
# See tasks/TASK-001-virtualbox-sandbox-architecture.md for full architecture.

Vagrant.configure("2") do |config|
  config.vm.box = "bento/ubuntu-24.04"  # Ubuntu 24.04 LTS
  config.vm.hostname = "aquarco"

  # Disable the default /vagrant sync — no host↔VM file sharing
  config.vm.synced_folder ".", "/vagrant", disabled: true

  # -------------------------------------------------------------------------
  # Dev mode — set AQUARCO_DEV=1 (or use: aquarco init --dev)
  # -------------------------------------------------------------------------
  if ENV['AQUARCO_DEV'] == '1'
    config.vm.synced_folder "..", "/home/agent/aquarco", type: "virtualbox"
    config.vm.synced_folder "../logs", "/var/log/aquarco-export",
      type: "virtualbox",
      create: true,
      mount_options: ["dmode=755", "fmode=644"]
  end

  # VirtualBox provider settings
  config.vm.provider "virtualbox" do |vb|
    vb.name = "aquarco"
    vb.memory = 6144
    vb.cpus = 3
    vb.gui = false

    # Performance settings (VirtualBox 7.2+ CLI flag names)
    vb.customize ["modifyvm", :id, "--ioapic", "on"]
    vb.customize ["modifyvm", :id, "--audio-enabled", "off"]
    vb.customize ["modifyvm", :id, "--usb-ohci", "off"]
  end

  # -------------------------------------------------------------------------
  # Port forwarding — Aquarco system ports
  # -------------------------------------------------------------------------
  aquarco_port = ENV.fetch('AQUARCO_PORT', '8080').to_i
  config.vm.network "forwarded_port", guest: 8080, host: aquarco_port, id: "proxy"  # Caddy reverse proxy (single entry point)
  config.vm.network "forwarded_port", guest: 5432, host: 15432, id: "postgres"    # PostgreSQL (system) — host 15432 to avoid local PG conflict

  # tools
  config.vm.network "forwarded_port", guest: 8085, host: 8085, id: "claude-spend"

  # -------------------------------------------------------------------------
  # Port forwarding — Repo slots (added/removed dynamically by manage-ports.sh
  # when repos are registered with the supervisor; these are placeholder slots)
  # -------------------------------------------------------------------------
  # Repo 1
  #config.vm.network "forwarded_port", guest: 3001, host: 3001, id: "repo1-fe"
  #config.vm.network "forwarded_port", guest: 4001, host: 4001, id: "repo1-api"
  #config.vm.network "forwarded_port", guest: 5433, host: 5433, id: "repo1-pg"
  # Repo 2
  #config.vm.network "forwarded_port", guest: 3002, host: 3002, id: "repo2-fe"
  #config.vm.network "forwarded_port", guest: 4002, host: 4002, id: "repo2-api"
  #config.vm.network "forwarded_port", guest: 5434, host: 5434, id: "repo2-pg"
  # Repo 3
  #config.vm.network "forwarded_port", guest: 3003, host: 3003, id: "repo3-fe"
  #config.vm.network "forwarded_port", guest: 4003, host: 4003, id: "repo3-api"
  #config.vm.network "forwarded_port", guest: 5435, host: 5435, id: "repo3-pg"
  # Repo 4
  #config.vm.network "forwarded_port", guest: 3004, host: 3004, id: "repo4-fe"
  #config.vm.network "forwarded_port", guest: 4004, host: 4004, id: "repo4-api"
  #config.vm.network "forwarded_port", guest: 5436, host: 5436, id: "repo4-pg"

  # -------------------------------------------------------------------------
  # Provisioning
  # -------------------------------------------------------------------------

  # Upload sibling scripts to /tmp/ so provision.sh can find them via SCRIPT_DIR
  config.vm.provision "file",
    source: "scripts/setup-network-tracking.sh",
    destination: "/tmp/setup-network-tracking.sh"

  config.vm.provision "shell",
    path: "scripts/provision.sh",
    env: { "AQUARCO_DOCKER_MODE" => ENV.fetch("AQUARCO_DOCKER_MODE", "development") }
end
