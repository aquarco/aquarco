# Vagrantfile — Aquarco VM
# Ubuntu 24.04 LTS with VirtualBox NAT networking and port forwarding
# See tasks/TASK-001-virtualbox-sandbox-architecture.md for full architecture.
#
# Two machines are always defined so vagrant can find them by name regardless
# of environment variables. Only one should run at a time (ports overlap).
#
#   aquarco      — production VM  (default, autostart)
#   aquarco-dev  — development VM (source tree mounted, not autostarted)

Vagrant.configure("2") do |config|
  {
    'aquarco'     => false,
    'aquarco-dev' => true,
  }.each do |vm_name, is_dev|
    config.vm.define vm_name, primary: !is_dev, autostart: !is_dev do |machine|
      machine.vm.box = "bento/ubuntu-24.04"  # Ubuntu 24.04 LTS
      machine.vm.hostname = vm_name

      # Disable the default /vagrant sync — no host↔VM file sharing
      machine.vm.synced_folder ".", "/vagrant", disabled: true

      # -----------------------------------------------------------------------
      # Dev mode — mount the source tree and log directory into the VM
      # -----------------------------------------------------------------------
      if is_dev
        machine.vm.synced_folder "..", "/home/agent/aquarco", type: "virtualbox"
        machine.vm.synced_folder "../logs", "/var/log/aquarco-export",
          type: "virtualbox",
          create: true,
          mount_options: ["dmode=755", "fmode=644"]
      end

      # VirtualBox provider settings
      machine.vm.provider "virtualbox" do |vb|
        vb.name = vm_name
        vb.memory = 6144
        vb.cpus = 3
        vb.gui = false

        # Performance settings (VirtualBox 7.2+ CLI flag names)
        vb.customize ["modifyvm", :id, "--ioapic", "on"]
        vb.customize ["modifyvm", :id, "--audio-enabled", "off"]
        vb.customize ["modifyvm", :id, "--usb-ohci", "off"]
      end

      # -----------------------------------------------------------------------
      # Port forwarding — Aquarco system ports
      # -----------------------------------------------------------------------
      aquarco_port = ENV.fetch('AQUARCO_PORT', '8080').to_i
      machine.vm.network "forwarded_port", guest: 8080, host: aquarco_port, id: "proxy"  # Caddy reverse proxy (single entry point)
      machine.vm.network "forwarded_port", guest: 5432, host: 15432, id: "postgres"    # PostgreSQL (system) — host 15432 to avoid local PG conflict

      # -----------------------------------------------------------------------
      # Provisioning
      # -----------------------------------------------------------------------

      # Upload sibling scripts to /tmp/ so provision.sh can find them via SCRIPT_DIR
      machine.vm.provision "file",
        source: "scripts/setup-network-tracking.sh",
        destination: "/tmp/setup-network-tracking.sh"

      # Upload docker compose files so provision.sh can place them in
      # /home/agent/aquarco/docker/ (non-dev mode only; dev mode uses synced folder)
      #
      # Always remove the destination first: Vagrant's file provisioner uses scp,
      # which nests the source directory *inside* an existing destination on
      # re-provision, causing provision.sh to read stale files from the first run.
      machine.vm.provision "shell", inline: "rm -rf /tmp/aquarco-docker", run: "always"
      machine.vm.provision "file",
        source: "../docker",
        destination: "/tmp/aquarco-docker"

      machine.vm.provision "shell",
        path: "scripts/provision.sh",
        env: {
          "AQUARCO_DOCKER_MODE" => ENV.fetch("AQUARCO_DOCKER_MODE", "development"),
          "DEV_MODE" => is_dev ? "1" : "0",
        }
    end
  end
end
